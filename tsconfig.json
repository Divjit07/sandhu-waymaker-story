{
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "incremental": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "strictNullChecks": true,
    "target": "ES2022"
  },
  "exclude": [
    "node_modules",
    "playwright-fixture.ts",
    "playwright.config.ts",
    "src/test/**/*",
    "tests/**/*"
  ],
  "include": ["**/*.ts", "**/*.tsx"]
}
